# Cloudflare R2
R2_BUCKET_NAME=deplyzegpt-storage
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Firebase backend
FIREBASE_SERVICE_ACCOUNT_PATH=../serviceaccount.json

# Vertex AI Gemini
VERTEX_AI_PROJECT=vision-sys
VERTEX_AI_LOCATION=global
VERTEX_GCS_BUCKET=vision-sys.firebasestorage.app
GEMINI_MODEL=gemini-3-flash-preview

# LocateAnything-3B research preview
ENABLE_LOCATE_ANYTHING=false
LOCATE_ENDPOINT_URL=
LOCATE_ENDPOINT_AUDIENCE=
LOCATE_GENERATION_MODE=hybrid
LOCATE_TIMEOUT_SECONDS=600
LOCATE_RETRY_DELAY_SECONDS=5
LOCATE_MAX_NEW_TOKENS=8192
LOCATE_MAX_REQUEST_SIDE=1024
ENABLE_LOCATE_ANYTHING_VIDEO=false
LOCATE_VIDEO_MAX_DURATION_SECONDS=120
LOCATE_VIDEO_FRAME_TIMEOUT_SECONDS=180
LOCATE_VIDEO_JOB_TIMEOUT_SECONDS=1800
LOCATE_VIDEO_MAX_ANALYSIS_FRAMES=48
LOCATE_VIDEO_MAX_FRAMES=48
LOCATE_VIDEO_SAMPLE_SECONDS=2.5
LOCATE_VIDEO_SCENE_THRESHOLD=0.35
LOCATE_VIDEO_FRAME_BATCH_SIZE=4
LOCATE_VIDEO_TARGET_P95_SECONDS=180
LOCATE_BATCH_FALLBACK_TO_SEQUENTIAL=false

# Async video queue
VIDEO_TASKS_PROJECT=vision-sys
VIDEO_TASKS_LOCATION=europe-west1
VIDEO_TASKS_QUEUE=video-processing
VIDEO_WORKER_URL=
VIDEO_TASKS_SERVICE_ACCOUNT_EMAIL=
VIDEO_TASKS_OIDC_AUDIENCE=
VIDEO_TASKS_DISPATCH_DEADLINE_SECONDS=1800
VIDEO_INTERNAL_SHARED_SECRET=

# Locate worker batch backend
LOCATE_WORKER_BACKEND=vllm
LOCATE_OPENAI_BASE_URL=
LOCATE_OPENAI_API_KEY=
LOCATE_OPENAI_MODEL=nvidia/LocateAnything-3B
LOCATE_OPENAI_BATCH_CONCURRENCY=4
LOCATE_RAW_BATCH_SEQUENTIAL=false

# Frontend
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=
REACT_APP_BACKEND_URL=http://127.0.0.1:8000
REACT_APP_ENABLE_LOCATE_ANYTHING=false
REACT_APP_ENABLE_LOCATE_ANYTHING_VIDEO=false

# Backend runtime
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
